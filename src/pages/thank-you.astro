---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Thank You" description="Thanks for reaching out to Symmetry Health Care Consulting.">
  <section class="mx-auto max-w-2xl px-6 py-28 text-center">
    <h1 class="text-3xl font-bold text-brand-navy">Thanks for reaching out.</h1>
    <p class="mt-4 text-brand-slate">
      We've received your message and will get back to you within one
      business day.
    </p>
    <a
      href="/"
      class="mt-8 inline-block rounded-md bg-brand-navy px-6 py-3 font-semibold text-white hover:bg-brand-blue"
    >
      Back to home
    </a>
  </section>
</Layout>
