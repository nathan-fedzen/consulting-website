---
import { getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const contactPage = await getEntry('pages', 'contact');
const site = await getEntry('settings', 'site');
if (!contactPage || !site) throw new Error('Missing contact or site content entry');

const { contactHeading, contactIntro } = contactPage.data;
const { email, phoneDisplay, phoneHref } = site.data;
---

<Layout
  title="Contact"
  description="Get in touch with Symmetry Health Care Consulting to schedule a revenue cycle consultation."
>
  <section class="bg-brand-navy">
    <div class="mx-auto max-w-6xl px-6 py-16">
      <p class="text-sm font-semibold uppercase tracking-wide text-brand-teal">Contact</p>
      <h1 class="mt-3 text-4xl font-bold text-white">{contactHeading}</h1>
      <p class="mt-4 max-w-2xl text-slate-200">
        {contactIntro}
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 py-20">
    <div class="grid gap-12 md:grid-cols-3">
      <div data-reveal class="rounded-lg bg-brand-mist p-6">
        <p class="text-sm font-semibold text-brand-navy">Direct contact</p>
        <ul class="mt-3 space-y-2 text-sm text-brand-slate">
          <li>
            <span class="block font-medium text-brand-navy">Email</span>
            <a href={`mailto:${email}`} class="hover:text-brand-blue">
              {email}
            </a>
          </li>
          <li>
            <span class="block font-medium text-brand-navy">Phone</span>
            <a href={phoneHref} class="hover:text-brand-blue">{phoneDisplay}</a>
          </li>
        </ul>
      </div>

      <form
        name="contact"
        method="POST"
        action="/thank-you"
        data-netlify="true"
        netlify-honeypot="bot-field"
        data-astro-reload
        data-reveal
        style="transition-delay: 100ms"
        class="md:col-span-2"
      >
        <input type="hidden" name="form-name" value="contact" />
        <p class="hidden">
          <label>
            Don't fill this out if you're human: <input name="bot-field" />
          </label>
        </p>

        <div class="grid gap-6 sm:grid-cols-2">
          <div>
            <label for="name" class="text-sm font-medium text-brand-navy">Name</label>
            <input
              id="name"
              name="name"
              type="text"
              required
              class="mt-1 w-full rounded-md border border-brand-mist px-3 py-2 focus:border-brand-blue focus:outline-none"
            />
          </div>
          <div>
            <label for="email" class="text-sm font-medium text-brand-navy">Email</label>
            <input
              id="email"
              name="email"
              type="email"
              required
              class="mt-1 w-full rounded-md border border-brand-mist px-3 py-2 focus:border-brand-blue focus:outline-none"
            />
          </div>
          <div>
            <label for="phone" class="text-sm font-medium text-brand-navy">Phone (optional)</label>
            <input
              id="phone"
              name="phone"
              type="tel"
              class="mt-1 w-full rounded-md border border-brand-mist px-3 py-2 focus:border-brand-blue focus:outline-none"
            />
          </div>
          <div>
            <label for="organization" class="text-sm font-medium text-brand-navy">
              Organization (optional)
            </label>
            <input
              id="organization"
              name="organization"
              type="text"
              class="mt-1 w-full rounded-md border border-brand-mist px-3 py-2 focus:border-brand-blue focus:outline-none"
            />
          </div>
        </div>

        <div class="mt-6">
          <label for="message" class="text-sm font-medium text-brand-navy">
            How can we help?
          </label>
          <textarea
            id="message"
            name="message"
            rows="5"
            required
            class="mt-1 w-full rounded-md border border-brand-mist px-3 py-2 focus:border-brand-blue focus:outline-none"
          ></textarea>
        </div>

        <button
          type="submit"
          class="mt-6 rounded-md bg-brand-navy px-6 py-3 font-semibold text-white transition-all duration-200 ease-out hover:-translate-y-0.5 hover:bg-brand-blue hover:shadow-lg active:translate-y-0 active:scale-95"
        >
          Send Message
        </button>
      </form>
    </div>
  </section>
</Layout>
