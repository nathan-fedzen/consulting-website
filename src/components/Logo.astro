---
interface Props {
  variant?: 'dark' | 'light';
  showWordmark?: boolean;
}

const { variant = 'dark', showWordmark = true } = Astro.props;
const mainColor = variant === 'light' ? 'text-white' : 'text-brand-navy';
const subColor = variant === 'light' ? 'text-slate-300' : 'text-brand-slate';
---

<a href="/" class="flex items-center gap-2">
  <img
    src="/symmetry_logo-cropped.png"
    alt="Symmetry Health Care Consulting"
    class="h-9 w-9 shrink-0 object-contain"
  />
  {
    showWordmark && (
      <span class="text-lg leading-tight tracking-tight">
        <span class:list={['font-bold', mainColor]}>Symmetry</span>{' '}
        <span class:list={['font-normal', subColor]}>Healthcare Consulting</span>
      </span>
    )
  }
</a>
